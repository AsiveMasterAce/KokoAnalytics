@model KokoAnalytics.Models.ImportViewModel
@{
    ViewData["Title"] = "Easy Import";
}

<div class="container">
    <h1 class="mb-2">📥 Easy Import</h1>
    <p class="text-muted mb-4">Paste your entire WordPress database export below — we'll figure out the rest.</p>

    <!-- Step-by-step guide -->
    <div class="card bg-light mb-4 border-0 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">📋 How to get your data from WordPress</h5>
            <div class="row mt-3">
                <div class="col-md-4 mb-3">
                    <div class="card h-100 border-primary">
                        <div class="card-body text-center">
                            <div class="display-6 mb-2">1️⃣</div>
                            <h6>Open phpMyAdmin</h6>
                            <p class="text-muted small mb-0">
                                Log in to your hosting panel (cPanel, Plesk, etc.) and open <strong>phpMyAdmin</strong>.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card h-100 border-primary">
                        <div class="card-body text-center">
                            <div class="display-6 mb-2">2️⃣</div>
                            <h6>Export the tables</h6>
                            <p class="text-muted small mb-0">
                                Select your WordPress database → click <strong>Export</strong> → choose <strong>SQL</strong> format → click <strong>Go</strong>.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card h-100 border-primary">
                        <div class="card-body text-center">
                            <div class="display-6 mb-2">3️⃣</div>
                            <h6>Paste below</h6>
                            <p class="text-muted small mb-0">
                                Open the downloaded <code>.sql</code> file in Notepad, <strong>Select All</strong> → <strong>Copy</strong> → <strong>Paste</strong> below.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Live detection preview (updates as user types/pastes) -->
    <div id="detectionPanel" class="card mb-4 shadow-sm" style="display:none;">
        <div class="card-header"><strong>🔍 Detected in your paste</strong></div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-3">
                    <div id="detectSiteStats" class="bg-light rounded p-2">
                        <div class="fs-4">📊</div>
                        <small class="d-block fw-bold">Daily Stats</small>
                        <span class="badge bg-secondary" id="badgeSiteStats">Not found</span>
                    </div>
                </div>
                <div class="col-3">
                    <div id="detectPostStats" class="bg-light rounded p-2">
                        <div class="fs-4">📄</div>
                        <small class="d-block fw-bold">Page Views</small>
                        <span class="badge bg-secondary" id="badgePostStats">Not found</span>
                    </div>
                </div>
                <div class="col-3">
                    <div id="detectRefUrls" class="bg-light rounded p-2">
                        <div class="fs-4">🔗</div>
                        <small class="d-block fw-bold">Referrer URLs</small>
                        <span class="badge bg-secondary" id="badgeRefUrls">Not found</span>
                    </div>
                </div>
                <div class="col-3">
                    <div id="detectRefStats" class="bg-light rounded p-2">
                        <div class="fs-4">📈</div>
                        <small class="d-block fw-bold">Referrer Stats</small>
                        <span class="badge bg-secondary" id="badgeRefStats">Not found</span>
                    </div>
                </div>
            </div>
            <!-- Warnings shown before submit -->
            <div id="preWarnings" class="mt-3" style="display:none;"></div>
        </div>
    </div>

    <!-- Result area (shown after import) -->
    <div id="resultArea" style="display:none;"></div>

    <!-- Progress bar (hidden by default) -->
    <div id="progressContainer" class="mb-4" style="display:none;">
        <div class="d-flex justify-content-between mb-1">
            <strong id="progressLabel">Importing...</strong>
            <span id="progressPercent">0%</span>
        </div>
        <div class="progress" style="height: 24px;">
            <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated"
                 role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
            </div>
        </div>
    </div>

    <!-- Paste area -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Paste your SQL export here</strong>
            <span class="badge bg-secondary">Auto-detects all 4 Koko Analytics tables</span>
        </div>
        <div class="card-body">
            <textarea id="rawSqlInput" class="form-control font-monospace" rows="16"
                      placeholder="Just paste everything here.

It's OK if there are CREATE TABLE, DROP TABLE, or other statements mixed in — we only read the INSERT INTO lines for Koko Analytics tables."></textarea>
        </div>
    </div>

    <div class="d-flex mb-4 gap-3">
        <button type="button" id="btnImport" class="btn btn-primary btn-lg" disabled>
            🚀 Import Data
        </button>
        <a asp-action="Index" asp-controller="Import" class="btn btn-outline-secondary btn-lg">
            🔧 Switch to Advanced Import
        </a>
    </div>
</div>

@section Scripts {
<script>
    const textarea = document.getElementById('rawSqlInput');
    const btnImport = document.getElementById('btnImport');
    const detectionPanel = document.getElementById('detectionPanel');
    const preWarnings = document.getElementById('preWarnings');
    const progressContainer = document.getElementById('progressContainer');
    const progressBar = document.getElementById('progressBar');
    const progressLabel = document.getElementById('progressLabel');
    const progressPercent = document.getElementById('progressPercent');
    const resultArea = document.getElementById('resultArea');

    const easyImportUrl = '@Url.Action("EasyImportApi", "Import")';
    const dashboardUrl = '@Url.Action("Index", "Home")';

    const tables = [
        { key: 'site_stats',    badge: 'badgeSiteStats',  panel: 'detectSiteStats',  label: 'Daily Stats' },
        { key: 'post_stats',    badge: 'badgePostStats',  panel: 'detectPostStats',  label: 'Page Views' },
        { key: 'referrer_urls', badge: 'badgeRefUrls',    panel: 'detectRefUrls',    label: 'Referrer URLs' },
        { key: 'referrer_stats',badge: 'badgeRefStats',   panel: 'detectRefStats',   label: 'Referrer Stats' }
    ];

    // Count INSERT rows for a table pattern
    function countRows(sql, tableKey) {
        const pattern = new RegExp(
            'INSERT\\s+INTO\\s+[`"]?\\w*' + tableKey + '[`"]?\\s*(?:\\([^)]*\\)\\s*)?VALUES\\s*(.*?);',
            'gis'
        );
        let total = 0;
        let match;
        while ((match = pattern.exec(sql)) !== null) {
            const valuesBlock = match[1];
            const tuples = valuesBlock.match(/\([^)]+\)/g);
            total += tuples ? tuples.length : 0;
        }
        return total;
    }

    // Live detection as user pastes/types
    let debounceTimer;
    textarea.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(updateDetection, 300);
    });

    function updateDetection() {
        const sql = textarea.value;
        resultArea.style.display = 'none';

        if (!sql.trim()) {
            detectionPanel.style.display = 'none';
            btnImport.disabled = true;
            return;
        }

        detectionPanel.style.display = '';
        let foundAny = false;
        let warnings = [];

        tables.forEach(t => {
            const count = countRows(sql, t.key);
            const badge = document.getElementById(t.badge);
            const panel = document.getElementById(t.panel);

            if (count > 0) {
                foundAny = true;
                badge.textContent = count + ' row' + (count !== 1 ? 's' : '');
                badge.className = 'badge bg-success';
                panel.className = 'p-2 rounded bg-success bg-opacity-10 border border-success';
            } else {
                badge.textContent = 'Not found';
                badge.className = 'badge bg-secondary';
                panel.className = 'p-2 rounded bg-light';
                warnings.push(t.label + ' — not detected. That data won\'t be imported.');
            }
        });

        // Show warnings
        if (warnings.length > 0 && foundAny) {
            preWarnings.style.display = '';
            preWarnings.innerHTML =
                '<div class="alert alert-warning mb-0 py-2"><strong>⚠️ Heads up:</strong><ul class="mb-0 mt-1">' +
                warnings.map(w => '<li>' + w + '</li>').join('') +
                '</ul><small class="text-muted">This is OK if you only exported some tables. Only detected data will be imported.</small></div>';
        } else {
            preWarnings.style.display = 'none';
        }

        // Check for non-INSERT junk and give a friendly note
        const junkPattern = /CREATE\s+TABLE|DROP\s+TABLE|LOCK\s+TABLES|ALTER\s+TABLE|SET\s+/gi;
        if (sql.match(junkPattern)) {
            if (foundAny && warnings.length < 4) {
                // already found some tables, just note that junk is ignored
            }
        }

        btnImport.disabled = !foundAny;
    }

    // Progress simulation + AJAX submit
    btnImport.addEventListener('click', async function () {
        const sql = textarea.value.trim();
        if (!sql) return;

        // Reset UI
        btnImport.disabled = true;
        resultArea.style.display = 'none';
        progressContainer.style.display = '';
        setProgress(0, 'Validating your data...');

        // Simulate progress steps while waiting for server
        const steps = [
            { pct: 10, label: 'Scanning for Koko Analytics tables...', delay: 400 },
            { pct: 25, label: 'Parsing site stats...', delay: 600 },
            { pct: 40, label: 'Parsing page views...', delay: 500 },
            { pct: 55, label: 'Parsing referrer URLs...', delay: 400 },
            { pct: 70, label: 'Parsing referrer stats...', delay: 500 },
            { pct: 85, label: 'Saving to database...', delay: 800 }
        ];

        let stepIndex = 0;
        const stepInterval = setInterval(() => {
            if (stepIndex < steps.length) {
                setProgress(steps[stepIndex].pct, steps[stepIndex].label);
                stepIndex++;
            }
        }, 600);

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            const response = await fetch(easyImportUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ rawSqlDump: sql })
            });

            clearInterval(stepInterval);
            const data = await response.json();

            if (data.success) {
                setProgress(100, 'Import complete!');
                progressBar.classList.remove('progress-bar-animated');
                progressBar.classList.replace('bg-primary', 'bg-success') || progressBar.classList.add('bg-success');
                showResult(true, data);
            } else {
                setProgress(100, 'Import finished with issues');
                progressBar.classList.remove('progress-bar-animated');
                progressBar.classList.add('bg-warning');
                showResult(false, data);
            }
        } catch (err) {
            clearInterval(stepInterval);
            setProgress(100, 'Error');
            progressBar.classList.remove('progress-bar-animated');
            progressBar.classList.add('bg-danger');
            showResult(false, {
                success: false,
                totalRows: 0,
                errors: ['Connection error: ' + err.message],
                warnings: []
            });
        }

        btnImport.disabled = false;
    });

    function setProgress(pct, label) {
        progressBar.style.width = pct + '%';
        progressBar.setAttribute('aria-valuenow', pct);
        progressPercent.textContent = pct + '%';
        progressLabel.textContent = label;
    }

    function showResult(success, data) {
        let html = '';

        if (success) {
            html += '<div class="alert alert-success shadow-sm">';
            html += '<h5 class="mb-3">✅ Import successful!</h5>';
            html += '<div class="row mb-3 text-center">';
            html += resultCard('Daily Stats', data.siteStatsCount, 'primary');
            html += resultCard('Page Views', data.postStatsCount, 'success');
            html += resultCard('Referrer URLs', data.referrerUrlsCount, 'info');
            html += resultCard('Referrer Stats', data.referrerStatsCount, 'warning');
            html += '</div>';
            html += '<p class="mb-1"><strong>Total rows imported: ' + data.totalRows + '</strong></p>';
            html += '<a href="' + dashboardUrl + '" class="btn btn-primary mt-2">📊 Go to Dashboard</a>';
        } else {
            html += '<div class="alert alert-warning shadow-sm">';
            if (data.totalRows > 0) {
                html += '<h5 class="mb-3">⚠️ Imported with some issues</h5>';
                html += '<p><strong>' + data.totalRows + ' rows</strong> were imported successfully.</p>';
            } else {
                html += '<h5 class="mb-3">❌ Nothing was imported</h5>';
            }
        }

        // Warnings
        if (data.warnings && data.warnings.length > 0) {
            html += '<div class="mt-2"><strong>ℹ️ Notes:</strong><ul class="mb-0">';
            data.warnings.forEach(w => { html += '<li>' + escapeHtml(w) + '</li>'; });
            html += '</ul></div>';
        }

        // Errors
        if (data.errors && data.errors.length > 0) {
            html += '<div class="mt-2"><strong>🔴 Errors:</strong><ul class="mb-0">';
            data.errors.forEach(e => { html += '<li class="text-danger">' + escapeHtml(e) + '</li>'; });
            html += '</ul></div>';
        }

        html += '</div>';
        resultArea.innerHTML = html;
        resultArea.style.display = '';
    }

    function resultCard(label, count, color) {
        return '<div class="col-3">' +
            '<div class="border rounded p-2 bg-'+ color +' bg-opacity-10">' +
            '<div class="fs-4 fw-bold">' + (count || 0) + '</div>' +
            '<small>' + label + '</small></div></div>';
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
</script>

@* Hidden anti-forgery token for AJAX *@
<form id="tokenForm" style="display:none;">
    @Html.AntiForgeryToken()
</form>
}